# muster-receiver — per-install config. Copy to config.env (gitignored) and edit.

# Campfire base URL (the BFP fork on madara). Replies POST to <base><room.path>.
CAMPFIRE_BASE=https://campfire.bluefenix.net

MUSTER_PORT=8788

# Bind host. On macOS under launchd, binding to a SPECIFIC tailscale IP makes
# inbound connections time out (Local Network privacy gates the launchd process
# on a non-loopback interface bind) — so use 0.0.0.0 and rely on the token below
# + the host not being publicly reachable. On Linux, the tailscale IP is fine.
MUSTER_BIND_HOST=0.0.0.0

# Optional shared secret. If set, every bot's webhook URL in Campfire must end
# with ?token=<this>. Belt-and-suspenders on top of tailnet-only.
MUSTER_WEBHOOK_TOKEN=

# Roster of agents (slug -> identity). Copy roster.example.json -> roster.json.
ROSTER_FILE=./roster.json

# Claude Code CLI — must be installed AND authenticated on this host (Itachi).
CLAUDE_BIN=claude
AGENT_TIMEOUT_MS=120000

# Optional: comma-separated user names to never wake on (e.g. mute bot-to-bot
# loops by listing the other bots here).
MUSTER_IGNORE_USERS=
