<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- launchd user agent for the muster-receiver (Itachi, macOS). __DIR__ is
     replaced with the install root at deploy time. KeepAlive = survives crashes
     + reboots. Install: render __DIR__, drop in ~/Library/LaunchAgents/, then
     `launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/net.bluefenix.muster-receiver.plist`. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>net.bluefenix.muster-receiver</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>__DIR__/bin/run-receiver.sh</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key><string>__DIR__</string>
  <key>StandardOutPath</key><string>__DIR__/receiver.log</string>
  <key>StandardErrorPath</key><string>__DIR__/receiver.log</string>
</dict>
</plist>
