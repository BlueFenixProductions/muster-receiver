# muster JOIN — live war-room (Campfire) console config.
# Copy to campfire.env (gitignored) and fill in. Read by `/muster ahoy`.

MUSTER_BASE=https://campfire.bluefenix.net

# The war-room room id (the :id in /rooms/:id). Live: the "muster" room is id 3.
MUSTER_ROOM_ID=3

# A Campfire USER account the console logs in as — used ONLY to READ history
# (GET /rooms/:id/messages). Reading requires a session cookie; bots can't read.
MUSTER_CONSOLE_EMAIL=
MUSTER_CONSOLE_PASSWORD=

# A console BOT's key — used to POST (CSRF-exempt: /rooms/:id/bot/:bot_key/...).
# This is the Operator-seat's OWN identity in the room. Don't reuse an agent's
# key (muster's distinct-identity-per-agent rule applies to the console too).
MUSTER_CONSOLE_BOTKEY=
